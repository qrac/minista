{
  "name": "minista-monorepo",
  "version": "4.0.0-alpha.11",
  "private": true,
  "type": "module",
  "homepage": "https://minista.qranoko.jp",
  "scripts": {
    "play": "minista ./playground/_default",
    "play-build": "minista build ./playground/_default",
    "play-preview": "minista preview ./playground/_default",
    "test": "vitest run",
    "test:w": "vitest watch",
    "up": "npx npm-check-updates --deep",
    "up:u": "npx npm-check-updates --deep -u",
    "rev": "npx npm-replace-versions --ignore **/node_modules"
  },
  "workspaces": [
    "docs",
    "packages/*",
    "playground/*"
  ],
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.6",
    "vitest": "^3.1.1"
  }
}
