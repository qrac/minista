{
  "name": "minista-monorepo",
  "version": "4.0.0-alpha.17",
  "private": true,
  "type": "module",
  "workspaces": [
    "docs",
    "packages/*",
    "playground/*"
  ],
  "scripts": {
    "docs": "minista ./docs --host",
    "docs-build": "minista build ./docs",
    "docs-preview": "minista preview ./docs",
    "all-play-build": "npm-run-all2 play-build play-build:*",
    "play": "minista ./playground/_default",
    "play-build": "minista build ./playground/_default",
    "play-preview": "minista preview ./playground/_default",
    "play:public": "minista ./playground/public",
    "play-build:public": "minista build ./playground/public",
    "play-preview:public": "minista preview ./playground/public",
    "play:head": "minista ./playground/head",
    "play-build:head": "minista build ./playground/head",
    "play-preview:head": "minista preview ./playground/head",
    "play:layout": "minista ./playground/layout",
    "play-build:layout": "minista build ./playground/layout",
    "play-preview:layout": "minista preview ./playground/layout",
    "play:fetch": "minista ./playground/fetch",
    "play-build:fetch": "minista build ./playground/fetch",
    "play-preview:fetch": "minista preview ./playground/fetch",
    "play:mdx": "minista ./playground/mdx",
    "play-build:mdx": "minista build ./playground/mdx",
    "play-preview:mdx": "minista preview ./playground/mdx",
    "play:bundle": "minista ./playground/bundle",
    "play-build:bundle": "minista build ./playground/bundle",
    "play-preview:bundle": "minista preview ./playground/bundle",
    "play:entry": "minista ./playground/entry",
    "play-build:entry": "minista build ./playground/entry",
    "play-preview:entry": "minista preview ./playground/entry",
    "play:image": "minista ./playground/image",
    "play-build:image": "minista build ./playground/image",
    "play-preview:image": "minista preview ./playground/image",
    "play:svg": "minista ./playground/svg",
    "play-build:svg": "minista build ./playground/svg",
    "play-preview:svg": "minista preview ./playground/svg",
    "play:sprite": "minista ./playground/sprite",
    "play-build:sprite": "minista build ./playground/sprite",
    "play-preview:sprite": "minista preview ./playground/sprite",
    "play:comment": "minista ./playground/comment",
    "play-build:comment": "minista build ./playground/comment",
    "play-preview:comment": "minista preview ./playground/comment",
    "play:island": "minista ./playground/island",
    "play-build:island": "minista build ./playground/island",
    "play-preview:island": "minista preview ./playground/island",
    "play:search": "minista ./playground/search",
    "play-build:search": "minista build ./playground/search",
    "play-preview:search": "minista preview ./playground/search",
    "play:beautify": "minista ./playground/beautify",
    "play-build:beautify": "minista build ./playground/beautify",
    "play-preview:beautify": "minista preview ./playground/beautify",
    "play:archive": "minista ./playground/archive",
    "play-build:archive": "minista build ./playground/archive",
    "play-preview:archive": "minista preview ./playground/archive",
    "play:create": "cd ./playground/_create && create-minista",
    "test": "vitest run",
    "test:w": "vitest watch",
    "up": "npx npm-check-updates --deep",
    "up:u": "npx npm-check-updates --deep -u",
    "rev": "npx npm-replace-versions --deps minista --ignore **/node_modules",
    "release-next": "npm run release-next:main && npm run release-next:create",
    "release-next:main": "cd ./packages/minista && npm publish --tag=next",
    "release-next:create": "cd ./packages/create-minista && npm publish --tag=next"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/degit": "^2.8.6",
    "@types/js-beautify": "^1.14.3",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.0.1",
    "@types/picomatch": "^4.0.2",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "npm-run-all2": "^8.0.4",
    "preact": "^10.28.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rolldown-vite": "^7.2.11",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vitest": "^4.0.15"
  }
}
