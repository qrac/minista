{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noErrorTruncation": true,
    "jsx": "react-jsx",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true
  },
  "include": ["./docs", "./packages", "./vitest.config.ts"],
  "exclude": ["node_modules", "dist", "./playground"]
}
